# Database — choose Neon or Ubicloud
# Neon:    postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Ubicloud: postgresql://user:pass@host:5432/metricshour
DATABASE_URL=postgresql://user:password@host:5432/metricshour

# Upstash Redis — used for Celery broker AND live feed pub/sub
REDIS_URL=rediss://default:TOKEN@HOST:PORT

# Environment
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://metricshour.com

# AI — Gemini for G20/top corridors, DeepSeek for bulk (concurrent)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Stock data
MARKETSTACK_API_KEY=

# Cloudflare
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Cloudflare R2 — create key at: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_BUCKET_NAME=metricshour-assets
R2_ENDPOINT=https://<CF_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Cloudflare KV
CF_KV_NAMESPACE_ID=

# Cloudflare Pages Deploy Hook — triggers sitemap rebuild daily
# Create at: Cloudflare Pages → your project → Settings → Builds & Deployments → Deploy Hooks
CF_PAGES_DEPLOY_HOOK=

# IndexNow — fast URL submission to Bing, Yandex, Seznam, Naver
# Key file deployed at: https://metricshour.com/6f2e9bac2bb44ccc9b1f202cbf6e670f.txt
INDEXNOW_KEY=6f2e9bac2bb44ccc9b1f202cbf6e670f

# Google OAuth — Sign in with Google
# 1. Go to console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 2. Authorised redirect URI: https://api.metricshour.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=https://metricshour.com

# Telegram Bot — for price alerts delivery
# 1. Create bot with @BotFather → get token
# 2. Set webhook: curl "https://api.telegram.org/bot{TOKEN}/setWebhook?url=https://api.metricshour.com/api/alerts/telegram/webhook&secret_token={WEBHOOK_SECRET}"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Resend — transactional email (free: 3,000 emails/month)
# Sign up at resend.com → API keys → create key
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@metricshour.com
