# WireGuard config for Netcup (10.0.0.1) — /etc/wireguard/wg0.conf
# Generate keys: wg genkey | tee private.key | wg pubkey > public.key

[Interface]
PrivateKey = <NETCUP_PRIVATE_KEY>
Address = 10.0.0.1/24
ListenPort = 51820

[Peer]
# Hetzner Finland
PublicKey = <HETZNER_PUBLIC_KEY>
AllowedIPs = 10.0.0.2/32
Endpoint = 89.167.35.114:51820
PersistentKeepalive = 25
